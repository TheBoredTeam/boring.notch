# Configuration for scripts/release.sh
#
# Copy this file to .env.local (gitignored) and fill in real values.
# .env.local is auto-sourced by the release script.

# Developer ID Application certificate identity, as printed by
#   security find-identity -v -p codesigning
# Example: "Developer ID Application: Your Name (L6U44C67P5)"
MACOS_SIGNING_IDENTITY=""

# Path on disk to the App Store Connect API key (.p8 file).
# Create at https://appstoreconnect.apple.com/access/integrations/api
APP_STORE_CONNECT_API_KEY=""

# 10-character Key ID printed next to the key in App Store Connect.
APP_STORE_CONNECT_API_KEY_ID=""

# UUID-format Issuer ID printed at the top of the Keys page.
APP_STORE_CONNECT_API_KEY_ISSUER_ID=""

# Path on disk to the Sparkle EdDSA private key file you exported with:
#   sparkle-bin/generate_keys -x sparkle_ed_private_key.txt
# This file is highly sensitive. Keep it out of cloud storage and backed up offline.
SPARKLE_PRIVATE_ED_KEY=""
