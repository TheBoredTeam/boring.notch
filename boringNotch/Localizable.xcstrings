    "Sneak Peek shows the media title and artist under the notch for a few seconds." : {
      "localizations" : {
        "cs" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Náhled zobrazuje název skladby a autora pod výřezem na několik vteřin."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Sneak Peek zeigt für ein paar Sekunden den Medientitel und den Künstler unter der Notch an."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Sneak Peek shows the media title and artist under the notch for a few seconds."
          }
        },
        "en-GB" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Sneak Peek shows the media title and artist under the notch for a few seconds."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Vistazo Rápido muestra el título y nombre del artista debajo del notch por unos segundos."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Sneak Peek montre le titre du média et l'artiste sous l'encoche pendant quelques secondes."
          }
        },
        "he" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "\"הצצה מהירה\" מציגה את שם המדיה והאמן מתחת למגרעת למשך מספר שניות."
          }
        },
        "hu" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "A Betekintés néhány másodpercre megjeleníti a média címét és az előadót a notch alatt."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Sneak Peek mostra per alcuni secondi il titolo dei media e l'artista sotto la notch."
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "훔쳐보기가 몇 초 동안 미디어 제목과 아티스트명을 노치 아래에 보여줍니다."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
