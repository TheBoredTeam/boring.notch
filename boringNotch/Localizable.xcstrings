        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Passen Sie an, welche Steuerelemente im Musik-Player angezeigt werden. Die Lautstärke wird erweitert, wenn aktiviert."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Customize which controls appear in the music player. Volume expands when active."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Personalice qué controles aparecen en el reproductor de música. El volumen se expande cuando está activo."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Personnaliser les contrôles présents dans le lecteur de musique. L'illustration s'agrandit durant l'activité."
          }
        },
        "he" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "בחר אילו פקדים יופיעו בנגן המוזיקה. בורר עוצמת הקול מתרחב כשהוא פעיל."
          }
        },
        "hu" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Válaszd ki a zenelejátszó vezérlőit. A hangerő aktív állapotban kibővül."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Personalizza quali controlli appaiono nel lettore musicale. Il volume si espande quando è attivo."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "ミュージックプレーヤーに表示するコントロールをカスタマイズします。音量はアクティブ時に展開されます。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "음악 플레이어에 표시할 컨트롤을 사용자 지정하세요. 볼륨은 활성화되면 확장됩니다."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Dostosuj które ustawienia wyświetlane w odtwarzaczu muzyki. Głośność rozwija się, gdy jest aktywna."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Personalize quais controles aparecem no player de música. O volume se expande quando ativo."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Настройте элементы управления в плеере. Громкость разворачивается при активации."
          }
        },
        "tr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Müzik çalarda hangi kontrollerin görüneceğini özelleştirin. Etkinleştirildiğinde ses seviyesi artar."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Налаштуйте, які елементи керування відображатимуться в музичному програвачі. Гучність збільшується, коли активна."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "自定义音乐播放器里出现的按钮，音量部分激活后会自动展开。"
          }
        },
        "zh-Hant-HK" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "自訂音樂播放器顯示按鈕，音量啟用時自動展開。"
          }
        }
      }
    },
