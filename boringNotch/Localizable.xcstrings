    "Boring Notch can check for updates in the background. You can still check manually from the menu bar at any time." : {
      "comment" : "A description of the software update permission.",
      "localizations" : {
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Notch d'ancrage peut vérifier les mises à jour en arrière-plan. Vous pouvez toujours vérifier manuellement à partir de la barre de menus à tout moment."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Boring Notch può controllare gli aggiornamenti in background. È comunque possibile controllare manualmente dalla barra dei menu in qualsiasi momento."
          }
        }
      }
    },
