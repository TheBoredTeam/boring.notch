          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Visualização rápida mostra o título da mídia e o artista sob o notch por alguns segundos."
          }
        },
        "ru" : {
          "stringUnit" : {
