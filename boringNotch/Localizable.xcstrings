    "Choose which service to use when sharing files from the shelf. Click the shelf button to select files, or drag files onto it to share immediately." : {
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Wählen Sie den zu verwendenden Dienst aus, wenn Dateien geteilt werden. Klicken Sie auf die Ablage-Taste, um Dateien auszuwählen oder ziehen Sie Dateien auf die Ablage, um sie sofort zu teilen."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Choose which service to use when sharing files from the shelf. Click the shelf button to select files, or drag files onto it to share immediately."
          }
        },
        "en-GB" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Choose which service to use when sharing files from the shelf. Click the shelf button to select files, or drag files onto it to share immediately."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Elija qué servicio usar al compartir archivos de la estantería. Haga clic en el botón de la estantería para seleccionar archivos, o arrástrelos a ella para compartirlos inmediatamente."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Choisir le service de partage à utiliser par l'étagère. Cliquer le service dans l'étagère, ou y glisser des fichiers pour les partager immédiatement."
          }
        },
        "he" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "בחר באיזה שירות להשתמש בעת שיתוף קבצים מהמדף. לחץ על כפתור המדף כדי לבחור קבצים, או גרור קבצים אליו לשיתוף מיידי."
          }
        },
        "hu" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Válaszd ki a megosztáshoz használni kívánt szolgáltatást. Kattints a polc gombra a fájlok tallózásához, vagy egyszerűen húzd rá a fájlokat az azonnali megosztáshoz."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Scegli quale servizio usare per la condivisione di file dallo scaffale. Fare clic sul pulsante scaffale per selezionare i file, o trascinare i file su di esso per condividere immediatamente."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "シェルフからファイルを共有する際に使用するサービスを選択します。シェルフボタンをクリックしてファイルを選択するか、ファイルをドラッグしてすぐに共有できます。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "선반에서 파일을 공유할 때 사용할 서비스를 선택하세요. 선반 버튼을 클릭해 파일을 선택하거나, 파일을 끌어다 놓으면 바로 공유할 수 있습니다."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Wybierz usługę używaną podczas udostępniania plików z półki. Kliknij przycisk półki, aby wybrać pliki, lub przeciągnij pliki na niego, aby udostępnić natychmiast."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Escolha qual serviço usar ao compartilhar arquivos da prateleira. Clique no botão da prateleira para selecionar arquivos ou arraste arquivos para ele para compartilhar imediatamente."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Выберите сервис для отправки файлов со стеллажа. Нажмите на кнопку стеллажа, чтобы выбрать файлы, или перетащите файлы на него для мгновенной отправки."
          }
        },
        "tr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Raftan dosya paylaşırken hangi hizmeti kullanacağınızı seçin. Dosyaları seçmek için raf düğmesine tıklayın veya anında paylaşmak için dosyaları rafa sürükleyin."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Оберіть сервіс для файлообміну у шухлядці. Для надсилання перейдіть до шухлядки й оберіть файли або одразу перетягніть їх до секції «Надсилання»."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "请选择分享文件的服务。您可以点击中转站按钮来选取文件，也可以直接将文件拖拽入中转站进行分享。"
          }
        },
        "zh-Hant-HK" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "揀定分享檔案嘅服務。點擊中轉站掣揀檔案，或者直接拖檔案入去即刻分享。"
          }
        }
      }
    },
