        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Concede permisos de Accesibilidad para que se puedan mostrar los controles de brillo del teclado incorporados."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Accorder l'accès à l'accès pour que les commandes de luminosité du clavier intégrées puissent être interceptées."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Permitir acesso à Acessibilidade para poder interceptar os controles de brilho embutidos do teclado."
