    "Calendar access is denied. Please enable it in System Settings." : {
      "localizations" : {
        "cs" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Přístup do kalendáře byl odepřen. Prosím povolte jej v nastavení systému."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Kalender Zugriff verweigert. Bitte aktiviere es in den Systemeinstellungen."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Calendar access is denied. Please enable it in System Settings."
          }
        },
        "en-GB" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Calendar access is denied. Please enable it in System Settings."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Acceso al calendario denegado. Por favor, habilítelo en Configuración del sistema."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "L'accès au calendrier est refusé. Veuillez l'activer dans les réglages."
          }
        },
        "he" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "הגישה ליומן נדחתה. אנא הפעל אותה בהגדרות המערכת."
          }
        },
        "hu" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Naptár hozzáférés megtagadva. Kérlek engedeéylezd a rendszerbeállításokban."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "L'accesso al calendario è negato. Si prega di abilitarlo nelle impostazioni di sistema."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "カレンダーへのアクセスが拒否されています。システム設定で有効にしてください。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "캘린더 권한 거부됨. 시스템 설정에서 허용해주세요.."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Dostęp do kalendarza został zablokowany. Proszę odblokować dostęp w Ustawieniach Systemowych."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Acesso ao Calendário negado. Por favor, autorize nas Configurações do Sistema."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Доступ к календарю запрещен. Пожалуйста, включите его в Системных настройках."
          }
        },
        "tr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Takvim erişimi reddedildi. Lütfen Sistem Ayarlarından izin verin."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Доступ до календаря заборонений. Будь ласка, увімкніть його в Налаштуваннях Системи."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "日历访问被拒绝。请在系统设置中启用它。"
          }
        },
        "zh-Hant-HK" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "日曆存取被拒絕，請喺系統設定度開啟佢。"
          }
        }
      }
    },
