          }
        },
        "en-GB": {
          "stringUnit": {
            "state": "translated",
            "value": "Sneak Peek shows the media title and artist under the notch for a few seconds."
          }
        },
        "es": {
          "stringUnit": {
            "state": "needs_review",
            "value": "Vistazo R\u00e1pido muestra el t\u00edtulo y nombre del artista debajo del notch por unos segundos."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "needs_review",
            "value": "Sneak Peek montre le titre du m\u00e9dia et l'artiste sous l'encoche pendant quelques secondes."
          }
        },
