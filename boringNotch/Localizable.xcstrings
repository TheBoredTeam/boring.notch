    "Select the music source you want to use. You can change this later in the app settings." : {
      "localizations" : {
        "cs" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Vyberte zdroj hudby který chcete používat. Můžete jej později změnit v nastavení aplikace."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Wähle die Musik Quelle aus, die du benutzen willst. Du kannst dies später in den Einstellungen ändern."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Select the music source you want to use. You can change this later in the app settings."
          }
        },
        "en-GB" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Select the music source you want to use. You can change this later in the app settings."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Seleccione la fuente de la música que desea utilizar. Puede cambiar esto más tarde en los ajustes de la aplicación."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Sélectionnez la source de musique que vous souhaitez utiliser. Vous pourrez la modifier plus tard dans les paramètres de l'application."
          }
        },
        "he" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "בחר את מקור המוזיקה בו תרצה להשתמש. תוכל לשנות זאת מאוחר יותר בהגדרות האפליקציה."
          }
        },
        "hu" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Válassza ki a használni kívánt zeneforrást. Ezt később bármikor módosíthatja az alkalmazás beállításaiban."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Selezionare la sorgente musicale che si desidera utilizzare. È possibile modificare questa impostazione in seguito nelle impostazioni dell'app."
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "음악 소스 선택하세요. 나중에 앱 설정에서 변경 가능합니다."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Wybierz źródło muzyki, którego chcesz użyć. Możesz to później zmienić w ustawieniach aplikacji."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Selecione a fonte de música que você deseja usar. Você poderá alterar isso mais tarde nas configurações do aplicativo."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Выберите источник музыки. Вы сможете изменить его позже в настройках приложения."
          }
        },
        "tr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Kullanmak istediğiniz müzik kaynağını seçin. Bunu daha sonra uygulama ayarlarından değiştirebilirsiniz."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Виберіть джерело музики для використання. Ви можете змінити це пізніше в налаштуваннях додатку."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
