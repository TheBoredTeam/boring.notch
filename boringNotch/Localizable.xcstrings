    "Sneak Peek shows the media title and artist under the notch for a few seconds.": {
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "needs_review",
            "value": "Sneak Peek shows the media title and artist under the notch for a few seconds."
          }
        },
        "cs": {
          "stringUnit": {
            "state": "needs_review",
            "value": "N\u00e1hled zobrazuje n\u00e1zev skladby a autora pod v\u00fd\u0159ezem na n\u011bkolik vte\u0159in."
          }
        },
        "de": {
          "stringUnit": {
            "state": "needs_review",
            "value": "Sneak Peek zeigt f\u00fcr ein paar Sekunden den Medientitel und den K\u00fcnstler unter der Notch an."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
